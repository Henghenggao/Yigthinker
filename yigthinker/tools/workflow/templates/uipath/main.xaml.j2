<?xml version="1.0" encoding="utf-8"?>
<Activity mc:Ignorable="sap sap2010"
          x:Class="Main"
          xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
          xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
          xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
          xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Sequence DisplayName="{{ display_name }}" sap2010:WorkflowViewState.IdRef="Sequence_Main">
    <!--
      Yigthinker placeholder - user MUST replace this comment with a Python Scope activity:
      1. Open this workflow in UiPath Studio.
      2. Drag "Python Scope" from the Activities panel into this Sequence.
      3. Set PythonVersion = Python_313 (or your installed version).
      4. Set Path to the parent folder of main.py.
      5. Drag "Run Python Script" inside the scope, point it at main.py.
      See setup_guide.md for screenshots.
    -->
  </Sequence>
</Activity>
