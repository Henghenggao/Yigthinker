"""Checkpoint utilities for {{ workflow_name }}.

Auto-generated by Yigthinker. Provides retry with self-healing callback,
status reporting, and Gateway integration (optional).

Gateway contract (Phase 10, CORR-01):
- POST /api/rpa/callback  -> D-08 payload (per-attempt self-heal request)
- POST /api/rpa/report    -> D-09 payload (run-level telemetry)

If the gateway is unavailable, the workflow escalates gracefully
(GW-RPA-05 fallback) instead of crashing.
"""
from __future__ import annotations

import functools
import logging
import time
import traceback
import uuid
from datetime import datetime, timezone
from typing import Any, Callable

logger = logging.getLogger("{{ workflow_name }}.checkpoint")

# Baked-in workflow variables
WORKFLOW_NAME = "{{ workflow_name }}"
WORKFLOW_VERSION = {{ workflow_version | default(1) }}
CHECKPOINT_IDS = {{ checkpoint_ids | tojson }}
MAX_RETRIES = {{ max_retries | default(3) }}
GATEWAY_URL = {{ gateway_url | tojson if gateway_url else 'None' }}

# Per-run identifiers populated by report_status(start=...)
_RUN_ID: str | None = None
_RUN_STARTED_AT: str | None = None


def _now_iso() -> str:
    """UTC ISO-8601 timestamp with timezone."""
    return datetime.now(timezone.utc).isoformat()


def _auth_headers(config: dict) -> dict[str, str]:
    """Build Authorization header from config.gateway_token (if present)."""
    headers = {"Content-Type": "application/json"}
    token = None
    if isinstance(config, dict):
        token = config.get("gateway_token")
    if token:
        headers["Authorization"] = f"Bearer {token}"
    return headers


def _summarize_inputs(kwargs: dict) -> dict:
    """Produce a safe, small inputs_summary dict for the gateway.

    Strips bulk objects (DataFrames, bytes) down to type+shape/length.
    """
    summary: dict[str, Any] = {}
    for key, value in (kwargs or {}).items():
        try:
            # pandas DataFrame -> shape
            shape = getattr(value, "shape", None)
            if shape is not None:
                summary[key] = {"type": type(value).__name__, "shape": list(shape)}
                continue
            if isinstance(value, (bytes, bytearray)):
                summary[key] = {"type": type(value).__name__, "length": len(value)}
                continue
            if isinstance(value, (str, int, float, bool)) or value is None:
                summary[key] = value
                continue
            if isinstance(value, (list, tuple, set)):
                summary[key] = {"type": type(value).__name__, "length": len(value)}
                continue
            if isinstance(value, dict):
                summary[key] = {"type": "dict", "length": len(value)}
                continue
            summary[key] = {"type": type(value).__name__}
        except Exception:
            summary[key] = {"type": "unknown"}
    return summary


def self_heal(
    checkpoint_id: str,
    error: Exception,
    attempt_number: int,
    context: dict,
    config: dict | None = None,
) -> dict:
    """Request self-healing guidance from Yigthinker Gateway.

    Gateway is optional -- if unavailable, falls back to escalate
    (GW-RPA-05 graceful fallback).

    POSTs a D-08 shaped payload to /api/rpa/callback:
        {
            "callback_id": <fresh uuid4>,
            "workflow_name": str,
            "version": int,
            "checkpoint_id": str,
            "attempt_number": int,
            "error_type": str,
            "error_message": str,
            "traceback": str,
            "step_context": {"name": str, "inputs_summary": dict},
        }
    """
    if GATEWAY_URL is None:
        return {"action": "escalate", "reason": "Gateway not configured"}

    cfg = config or {}
    payload = {
        "callback_id": str(uuid.uuid4()),
        "workflow_name": WORKFLOW_NAME,
        "version": WORKFLOW_VERSION,
        "checkpoint_id": checkpoint_id,
        "attempt_number": attempt_number,
        "error_type": type(error).__name__,
        "error_message": str(error),
        "traceback": "".join(
            traceback.format_exception(type(error), error, error.__traceback__)
        ),
        "step_context": {
            "name": checkpoint_id,
            "inputs_summary": _summarize_inputs(context),
        },
    }

    try:
        import requests  # noqa: F811
        resp = requests.post(
            f"{GATEWAY_URL}/api/rpa/callback",
            json=payload,
            headers=_auth_headers(cfg),
            timeout=10,
        )
        resp.raise_for_status()
        return resp.json()
    except (ConnectionError, OSError) as exc:
        logger.warning("Gateway unavailable for self-healing: %s", exc)
        return {"action": "escalate", "reason": "Gateway unavailable"}
    except Exception as exc:
        logger.warning("Self-healing request failed: %s", exc)
        return {"action": "escalate", "reason": str(exc)}


def checkpoint(
    checkpoint_id: str,
    max_retries: int = MAX_RETRIES,
    config: dict | None = None,
) -> Callable:
    """Decorator wrapping a step function with retry + self-healing."""
    def decorator(func: Callable) -> Callable:
        @functools.wraps(func)
        def wrapper(*args: Any, **kwargs: Any) -> Any:
            last_error: Exception | None = None
            for attempt in range(1, max_retries + 1):
                try:
                    result = func(*args, **kwargs)
                    logger.info(
                        "Checkpoint %s passed (attempt %d/%d)",
                        checkpoint_id, attempt, max_retries,
                    )
                    return result
                except Exception as exc:
                    last_error = exc
                    logger.warning(
                        "Checkpoint %s failed (attempt %d/%d): %s",
                        checkpoint_id, attempt, max_retries, exc,
                    )
                    if attempt < max_retries:
                        guidance = self_heal(
                            checkpoint_id=checkpoint_id,
                            error=exc,
                            attempt_number=attempt,
                            context=kwargs,
                            config=config,
                        )
                        if guidance.get("action") == "escalate":
                            logger.error(
                                "Escalating %s: %s",
                                checkpoint_id, guidance.get("reason"),
                            )
                            break
                        # Apply guidance and retry
                        delay = guidance.get("retry_delay_s") or 1
                        try:
                            time.sleep(float(delay))
                        except (TypeError, ValueError):
                            time.sleep(1)
            raise RuntimeError(
                f"Checkpoint {checkpoint_id} failed after {max_retries} attempts: {last_error}"
            )
        return wrapper
    return decorator


def report_status(
    status: str,
    config: dict | None = None,
    error_summary: str | None = None,
    start: bool = False,
) -> None:
    """Report workflow status to Yigthinker Gateway (optional).

    POSTs a D-09 shaped payload to /api/rpa/report:
        {
            "workflow_name": str,
            "version": int,
            "run_id": str,
            "started_at": iso8601 str,
            "finished_at": iso8601 str,
            "status": "success" | "failure" | "partial",
            "error_summary": str | None,
        }

    Call with start=True at the top of the run to initialize run_id +
    started_at.  Subsequent calls use those cached values as finished_at
    is set to "now".
    """
    global _RUN_ID, _RUN_STARTED_AT

    if start:
        _RUN_ID = str(uuid.uuid4())
        _RUN_STARTED_AT = _now_iso()
        return

    if _RUN_ID is None or _RUN_STARTED_AT is None:
        _RUN_ID = str(uuid.uuid4())
        _RUN_STARTED_AT = _now_iso()

    if GATEWAY_URL is None:
        logger.info("Status: %s (Gateway not configured, skipping report)", status)
        return

    cfg = config or {}
    payload = {
        "workflow_name": WORKFLOW_NAME,
        "version": WORKFLOW_VERSION,
        "run_id": _RUN_ID,
        "started_at": _RUN_STARTED_AT,
        "finished_at": _now_iso(),
        "status": status,
        "error_summary": error_summary,
    }

    try:
        import requests  # noqa: F811
        requests.post(
            f"{GATEWAY_URL}/api/rpa/report",
            json=payload,
            headers=_auth_headers(cfg),
            timeout=10,
        )
    except (ConnectionError, OSError) as exc:
        logger.warning("Gateway unavailable for status report: %s", exc)
    except Exception as exc:
        logger.warning("Status report failed: %s", exc)
