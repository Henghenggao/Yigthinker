"""Checkpoint utilities for {{ workflow_name }}.

Auto-generated by Yigthinker. Provides retry with self-healing callback,
status reporting, and Gateway integration (optional).
"""
from __future__ import annotations

import functools
import json
import logging
import time
from typing import Any, Callable

logger = logging.getLogger("{{ workflow_name }}.checkpoint")

# Baked-in workflow variables
WORKFLOW_NAME = "{{ workflow_name }}"
CHECKPOINT_IDS = {{ checkpoint_ids | tojson }}
MAX_RETRIES = {{ max_retries | default(3) }}
GATEWAY_URL = {{ gateway_url | tojson if gateway_url else 'None' }}


def self_heal(checkpoint_id: str, error: Exception, context: dict) -> dict:
    """Request self-healing guidance from Yigthinker Gateway.

    Gateway is optional -- if unavailable, falls back to escalate.
    """
    if GATEWAY_URL is None:
        return {"action": "escalate", "reason": "Gateway not configured"}

    try:
        import requests  # noqa: F811
        resp = requests.post(
            f"{GATEWAY_URL}/api/rpa/heal",
            json={
                "workflow": WORKFLOW_NAME,
                "checkpoint": checkpoint_id,
                "error": str(error),
                "context": context,
            },
            timeout=10,
        )
        resp.raise_for_status()
        return resp.json()
    except (ConnectionError, OSError) as exc:
        logger.warning("Gateway unavailable for self-healing: %s", exc)
        return {"action": "escalate", "reason": "Gateway unavailable"}
    except Exception as exc:
        logger.warning("Self-healing request failed: %s", exc)
        return {"action": "escalate", "reason": str(exc)}


def checkpoint(
    checkpoint_id: str,
    max_retries: int = MAX_RETRIES,
) -> Callable:
    """Decorator wrapping a step function with retry + self-healing."""
    def decorator(func: Callable) -> Callable:
        @functools.wraps(func)
        def wrapper(*args: Any, **kwargs: Any) -> Any:
            last_error: Exception | None = None
            for attempt in range(1, max_retries + 1):
                try:
                    result = func(*args, **kwargs)
                    logger.info(
                        "Checkpoint %s passed (attempt %d/%d)",
                        checkpoint_id, attempt, max_retries,
                    )
                    return result
                except Exception as exc:
                    last_error = exc
                    logger.warning(
                        "Checkpoint %s failed (attempt %d/%d): %s",
                        checkpoint_id, attempt, max_retries, exc,
                    )
                    if attempt < max_retries:
                        guidance = self_heal(checkpoint_id, exc, kwargs)
                        if guidance.get("action") == "escalate":
                            logger.error(
                                "Escalating %s: %s",
                                checkpoint_id, guidance.get("reason"),
                            )
                            break
                        # Apply guidance and retry
                        time.sleep(1)
            raise RuntimeError(
                f"Checkpoint {checkpoint_id} failed after {max_retries} attempts: {last_error}"
            )
        return wrapper
    return decorator


def report_status(status: str, config: dict) -> None:
    """Report workflow status to Yigthinker Gateway (optional)."""
    if GATEWAY_URL is None:
        logger.info("Status: %s (Gateway not configured, skipping report)", status)
        return

    try:
        import requests  # noqa: F811
        requests.post(
            f"{GATEWAY_URL}/api/rpa/report",
            json={
                "workflow": WORKFLOW_NAME,
                "status": status,
            },
            timeout=10,
        )
    except (ConnectionError, OSError) as exc:
        logger.warning("Gateway unavailable for status report: %s", exc)
    except Exception as exc:
        logger.warning("Status report failed: %s", exc)
