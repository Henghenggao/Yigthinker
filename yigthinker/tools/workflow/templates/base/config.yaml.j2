# Auto-generated by Yigthinker -- DO NOT commit credentials to version control
# Use vault:// references or environment variables for secrets
workflow_name: "{{ workflow_name }}"
version: "v{{ version }}"

{% for conn_name in connections %}
{{ conn_name }}:
  connection_string: "vault://{{ conn_name }}/connection_string"  # TODO: configure in vault
{% endfor %}

{% if schedule %}
schedule: "{{ schedule }}"
{% endif %}

# Yigthinker Gateway (optional -- self-healing only)
yigthinker_gateway: null
gateway_token: null
