#!/usr/bin/env python3
"""{{ workflow_name }} — self-contained AR aging report
Auto-generated by Yigthinker from ar_aging.py.j2 (ADR-011 Track B2).

Runs WITHOUT Yigthinker in the loop. Reads config.yaml beside this script
for connection + delivery settings, queries open AR, buckets by age, and
writes a styled xlsx with a native openpyxl bar chart embedded. Deploy
this via the PA / UiPath / OS scheduler modes produced by
``workflow_deploy``.

Architect-not-executor invariant: any attempt to import ``yigthinker`` or
call back into a gateway belongs in a SEPARATE optional module
(checkpoint_utils.py in sister templates). This file stays pure Python.
"""
from __future__ import annotations

import logging
import sys
from datetime import datetime, date
from pathlib import Path

import pandas as pd
import yaml
from sqlalchemy import create_engine, text

import openpyxl
from openpyxl.chart import BarChart, Reference
from openpyxl.styles import Font, PatternFill, Alignment
from openpyxl.utils import get_column_letter

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s %(levelname)s {{ workflow_name }}: %(message)s",
)
logger = logging.getLogger("{{ workflow_name }}")


# ── Aging bucket semantics (locked by Track B2 contract) ─────────────────
#
# Must match yigthinker/commands/finance/ar-aging.md §3 — any change to
# these bucket labels must also update the recipe file or the /ar-aging
# command output will drift from the deployed workflow's output.
AGING_BUCKETS = [
    ("0-30", 0, 30),
    ("31-60", 31, 60),
    ("61-90", 61, 90),
    ("90+", 91, None),  # None = no upper bound
]


def load_config() -> dict:
    """Load config.yaml from the script's directory.

    config.yaml must contain:
      connection_string: str   # vault:// refs resolved by deploy helper
      ar_table: str            # e.g. "accounts_receivable"
      customer_col: str        # default "customer_id"
      customer_name_col: str   # optional
      amount_col: str          # default "amount_due"
      due_date_col: str        # default "due_date"
      status_col: str          # optional — filter to open invoices
      output_dir: str          # where to write the xlsx
      as_of_date: str          # optional YYYY-MM-DD, defaults to today
    """
    config_path = Path(__file__).parent / "config.yaml"
    with open(config_path, encoding="utf-8") as f:
        return yaml.safe_load(f) or {}


def resolve_as_of_date(config: dict) -> date:
    """as_of_date from config.yaml or default to today. Returns a
    ``date`` object usable in pandas timedelta math."""
    raw = config.get("as_of_date")
    if not raw:
        return datetime.now().date()
    if isinstance(raw, date):
        return raw
    return datetime.strptime(str(raw), "%Y-%m-%d").date()


def fetch_open_ar(config: dict, as_of: date) -> pd.DataFrame:
    """Query open AR as of the target date. Returns a DataFrame with at
    minimum ``customer_id`` / ``amount_due`` / ``due_date`` columns
    (whatever the config says they're actually called in the table)."""
    engine = create_engine(config["connection_string"])

    customer_col = config.get("customer_col", "{{ customer_col | default('customer_id') }}")
    amount_col = config.get("amount_col", "{{ amount_col | default('amount_due') }}")
    due_date_col = config.get("due_date_col", "{{ due_date_col | default('due_date') }}")
    ar_table = config.get("ar_table", "{{ ar_table | default('accounts_receivable') }}")
    status_col = config.get("status_col")
    customer_name_col = config.get("customer_name_col")

    cols = [customer_col, amount_col, due_date_col]
    if customer_name_col:
        cols.append(customer_name_col)
    col_list = ", ".join(f'"{c}"' for c in cols)

    query = f'SELECT {col_list} FROM "{ar_table}"'
    if status_col:
        query += f' WHERE lower("{status_col}") IN (\'open\', \'unpaid\', \'pending\')'

    logger.info("Fetching open AR as of %s", as_of.isoformat())
    with engine.connect() as conn:
        df = pd.read_sql(text(query), conn)

    if df.empty:
        logger.warning("No open AR rows returned — producing empty aging report")
    return df


def compute_buckets(df: pd.DataFrame, as_of: date, config: dict) -> pd.DataFrame:
    """Bucket every invoice into 0-30 / 31-60 / 61-90 / 90+ days past due,
    then aggregate total amount per bucket. Returns a 4-row DataFrame
    (one per bucket) even if some buckets are empty — downstream chart
    rendering is cleaner when every bucket has a row."""
    due_date_col = config.get("due_date_col", "{{ due_date_col | default('due_date') }}")
    amount_col = config.get("amount_col", "{{ amount_col | default('amount_due') }}")

    if df.empty:
        return pd.DataFrame(
            [{"age_bucket": label, "total_amount_due": 0.0} for label, _, _ in AGING_BUCKETS]
        )

    df = df.copy()
    df[due_date_col] = pd.to_datetime(df[due_date_col]).dt.date
    df["days_past_due"] = df[due_date_col].apply(lambda d: (as_of - d).days)

    def bucket_for(days: int) -> str:
        for label, lo, hi in AGING_BUCKETS:
            if hi is None:
                if days >= lo:
                    return label
            elif lo <= days <= hi:
                return label
        return "0-30"  # before-due invoices fall into 0-30

    df["age_bucket"] = df["days_past_due"].apply(bucket_for)

    # Aggregate, reindex so all four buckets appear even when empty
    agg = (
        df.groupby("age_bucket")[amount_col]
        .sum()
        .rename("total_amount_due")
        .reset_index()
    )
    labels = [label for label, _, _ in AGING_BUCKETS]
    out = (
        agg.set_index("age_bucket")
        .reindex(labels, fill_value=0.0)
        .reset_index()
    )
    return out


def write_xlsx_with_chart(summary: pd.DataFrame, as_of: date, output_path: Path) -> None:
    """Write the bucket summary + an embedded BarChart to an xlsx."""
    output_path.parent.mkdir(parents=True, exist_ok=True)
    wb = openpyxl.Workbook()
    ws = wb.active
    ws.title = "Aging Summary"

    # Styled header row
    header_fill = PatternFill(start_color="1E40AF", end_color="1E40AF", fill_type="solid")
    header_font = Font(bold=True, color="FFFFFF")
    ws.cell(row=1, column=1, value="age_bucket").fill = header_fill
    ws.cell(row=1, column=1).font = header_font
    ws.cell(row=1, column=2, value="total_amount_due").fill = header_fill
    ws.cell(row=1, column=2).font = header_font
    ws.column_dimensions["A"].width = 14
    ws.column_dimensions["B"].width = 18

    # Data rows + number formatting
    for idx, (_, row) in enumerate(summary.iterrows(), start=2):
        ws.cell(row=idx, column=1, value=row["age_bucket"])
        cell = ws.cell(row=idx, column=2, value=float(row["total_amount_due"]))
        cell.number_format = "#,##0.00;[Red]-#,##0.00"

    # Freeze header, embed the bar chart
    ws.freeze_panes = "A2"

    chart = BarChart()
    chart.type = "col"
    chart.title = f"AR Aging by Bucket — as of {as_of.isoformat()}"
    data_ref = Reference(
        ws, min_col=2, max_col=2,
        min_row=1, max_row=1 + len(summary),
    )
    cats_ref = Reference(
        ws, min_col=1, max_col=1,
        min_row=2, max_row=1 + len(summary),
    )
    chart.add_data(data_ref, titles_from_data=True)
    chart.set_categories(cats_ref)
    ws.add_chart(chart, "D1")

    wb.save(str(output_path))
    logger.info("Wrote xlsx to %s", output_path)


def main() -> int:
    try:
        config = load_config()
    except Exception as exc:
        logger.error("Failed to load config.yaml: %s", exc)
        return 2

    try:
        as_of = resolve_as_of_date(config)
        df = fetch_open_ar(config, as_of)
        summary = compute_buckets(df, as_of, config)

        output_dir = Path(config.get("output_dir", ".")).expanduser()
        output_path = output_dir / f"ar_aging_{as_of.isoformat()}.xlsx"
        write_xlsx_with_chart(summary, as_of, output_path)

        total_ar = float(summary["total_amount_due"].sum())
        pct_90plus = (
            float(summary.loc[summary["age_bucket"] == "90+", "total_amount_due"].sum())
            / total_ar * 100.0
            if total_ar > 0 else 0.0
        )
        logger.info(
            "AR aging complete: total=%.2f, 90+ bucket share=%.1f%%, path=%s",
            total_ar, pct_90plus, output_path,
        )
        return 0
    except Exception as exc:
        logger.exception("AR aging workflow failed: %s", exc)
        return 1


if __name__ == "__main__":
    sys.exit(main())
