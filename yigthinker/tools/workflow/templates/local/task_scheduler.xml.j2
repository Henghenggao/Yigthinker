<?xml version="1.0" encoding="UTF-8"?>
<Task version="1.3" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <Date>{{ registration_date }}</Date>
    <Author>Yigthinker</Author>
    <Description>Auto-generated: {{ workflow_name }} — {{ description }}</Description>
    <URI>\Yigthinker\{{ workflow_name }}</URI>
  </RegistrationInfo>
  <Triggers>
    <CalendarTrigger>
      <StartBoundary>{{ trigger.start_boundary }}</StartBoundary>
      <Enabled>true</Enabled>
{% if trigger.kind == "calendar_daily" %}
      <ScheduleByDay>
        <DaysInterval>1</DaysInterval>
      </ScheduleByDay>
{% elif trigger.kind == "calendar_monthly" %}
      <ScheduleByMonth>
        <DaysOfMonth>
          <Day>{{ trigger.day_of_month }}</Day>
        </DaysOfMonth>
        <Months>
          <January/><February/><March/><April/><May/><June/>
          <July/><August/><September/><October/><November/><December/>
        </Months>
      </ScheduleByMonth>
{% elif trigger.kind == "calendar_weekly" %}
      <ScheduleByWeek>
        <DaysOfWeek>
          <{{ trigger.day_of_week }}/>
        </DaysOfWeek>
        <WeeksInterval>1</WeeksInterval>
      </ScheduleByWeek>
{% elif trigger.kind == "calendar_hourly" %}
      <ScheduleByDay>
        <DaysInterval>1</DaysInterval>
      </ScheduleByDay>
      <Repetition>
        <Interval>PT{{ trigger.interval_hours }}H</Interval>
        <Duration>P1D</Duration>
      </Repetition>
{% else %}
      <ScheduleByDay>
        <DaysInterval>1</DaysInterval>
      </ScheduleByDay>
{% endif %}
    </CalendarTrigger>
  </Triggers>
  <Principals>
    <Principal id="Author">
      <LogonType>InteractiveToken</LogonType>
      <RunLevel>LeastPrivilege</RunLevel>
    </Principal>
  </Principals>
  <Settings>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
    <DisallowStartIfOnBatteries>false</DisallowStartIfOnBatteries>
    <StopIfGoingOnBatteries>false</StopIfGoingOnBatteries>
    <AllowHardTerminate>true</AllowHardTerminate>
    <StartWhenAvailable>true</StartWhenAvailable>
    <RunOnlyIfNetworkAvailable>false</RunOnlyIfNetworkAvailable>
    <IdleSettings>
      <StopOnIdleEnd>true</StopOnIdleEnd>
      <RestartOnIdle>false</RestartOnIdle>
    </IdleSettings>
    <AllowStartOnDemand>true</AllowStartOnDemand>
    <Enabled>true</Enabled>
    <Hidden>false</Hidden>
    <RunOnlyIfIdle>false</RunOnlyIfIdle>
    <WakeToRun>false</WakeToRun>
    <ExecutionTimeLimit>PT1H</ExecutionTimeLimit>
    <Priority>7</Priority>
  </Settings>
  <Actions Context="Author">
    <Exec>
      <Command>{{ python_exe }}</Command>
      <Arguments>main.py</Arguments>
      <WorkingDirectory>{{ working_dir }}</WorkingDirectory>
    </Exec>
  </Actions>
</Task>
